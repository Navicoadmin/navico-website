# ====== NAVICO - Biến môi trường ======
# Sao chép file này thành .env và điền giá trị thật.

# Kết nối PostgreSQL (Prisma)
DATABASE_URL="postgresql://navico:your_password@localhost:5432/navico?schema=public"

# URL gốc của site (dùng cho SEO, sitemap, OG)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# JWT - chuỗi bí mật ký token (đổi sang chuỗi ngẫu nhiên dài khi production)
JWT_SECRET="doi-thanh-chuoi-bi-mat-that-dai-va-ngau-nhien"

# Thời gian sống của phiên đăng nhập admin (giây) - mặc định 7 ngày
SESSION_MAX_AGE="604800"

# Tài khoản admin được tạo khi chạy seed
ADMIN_EMAIL="admin@navico.vn"
ADMIN_PASSWORD="Navico@123"

# Chatbox AI (OpenAI). Để trống thì chatbox báo "đang cấu hình".
# Lấy key tại https://platform.openai.com/api-keys
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"
